FLASK_APP=app.py
FLASK_SECRET_KEY=change-me
GEMINI_API_KEY=<APIKEY>
GEMINI_MODEL=gemini-2.5-flash-image
PLOTTER_SERIAL_PORT=/dev/tty.usbserial-11140
PLOTTER_BAUDRATE=115200
PLOTTER_SERIAL_TIMEOUT=5.0
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=60
PLOTTER_DRY_RUN=false
PLOTTER_INVERT_Z=true
PLOTTER_LINE_DELAY=0.1
PLOTTER_VECTOR_RESOLUTION=1600
PLOTTER_VECTORIZE_THRESHOLD=240
PLOTTER_VECTORIZE_SIMPLIFY_PX=2.0
PLOTTER_VECTORIZE_MIN_POINTS=24
PLOTTER_VECTORIZE_DOWNSAMPLE_STEP=1
PLOTTER_VECTORIZE_STROKE_WIDTH=3.0
PLOTTER_VECTORIZE_CROP_PADDING_RATIO=0.05
ENABLE_MANUAL_UPLOAD=false

# Chess robot
CHESS_BOARD_SIZE_MM=215.9
CHESS_SQUARE_COUNT=8
CHESS_GAP_MM=2.0
CHESS_ORIGIN_X_MM=0.0
CHESS_ORIGIN_Y_MM=0.0
CHESS_MIRROR_RANKS=false
CHESS_TAP_DWELL_S=0.3
CHESS_SOURCE_SETTLE_S=0.05
CHESS_PICKUP_DWELL_S=0.2
CHESS_PLACE_DWELL_S=0.15

# Pi electromagnet (BCM pin 12 = GPIO 12). Off on dev/CI unless enabled.
ELECTROMAGNET_ENABLED=false
ELECTROMAGNET_BCM_PIN=12
ELECTROMAGNET_PWM_FREQUENCY_HZ=1000

# Chess electromagnet control
CHESS_MAGNET_ON_GCODE=M3 S255
CHESS_MAGNET_OFF_GCODE=M3 S0\nM5
CHESS_MAGNET_ENGAGE_DWELL_S=0.3
CHESS_MAGNET_RELEASE_DWELL_S=0.3
CHESS_MOVE_FEED_RATE=3000
CHESS_CAPTURE_X_MM=-30.0
CHESS_CAPTURE_Y_MM=0.0
CHESS_CAPTURE_SPACING_MM=15.0
CHESS_HOME_AFTER_MOVE=false
