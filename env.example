# FastAPI: run via python app.py or uvicorn main:app
FLASK_SECRET_KEY=change-me
ADMIN_PIN=1234

# Plotter (USB serial, no network)
PLOTTER_SERIAL_PORT=/dev/tty.usbserial-11140
PLOTTER_BAUDRATE=115200
PLOTTER_SERIAL_TIMEOUT=5.0
PLOTTER_DRY_RUN=false
PLOTTER_LINE_DELAY=0.1
PLOTTER_FEED_RATE=5000

# Chess play (offline: Stockfish + python-chess)
STOCKFISH_PATH=stockfish
# Optional: path to JSON with dimensions exported from CAD (env overrides JSON)
# CHESS_DIMENSIONS_JSON=./chess_dimensions.json
CHESS_BOARD_SIZE_MM=200.0
CHESS_SQUARE_COUNT=8
CHESS_ORIGIN_X_MM=0.0
CHESS_ORIGIN_Y_MM=0.0
# Discard pocket offset in board squares (README: origin - offset * square_size in X and Y)
# CHESS_DISCARD_OFFSET_SQUARES=1.5
CHESS_TAP_DWELL_S=0.3
CHESS_MAGNET_SETTLE_S=0.5
# Optional: for magnet-on-time warning when move exceeds max (rapid feed mm/s; max on-time s)
# CHESS_RAPID_FEED_MM_S=100.0
# CHESS_MAGNET_MAX_ON_S=5.0
